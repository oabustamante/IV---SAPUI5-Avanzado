<mvc:View controllerName="employees.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core">
    
    <Shell>
        <App id="app">
            <pages>
                <Page showHeader="false">
                    <content>
                        <f:FlexibleColumnLayout id="fcl" layout="{jsonLayout>/ActiveKey}" >
                            <f:beginColumnPages>
                                <mvc:XMLView id="masterEmployee" viewName="employees.view.MainView" />
                            </f:beginColumnPages>
                            <f:midColumnPages>
                                <mvc:XMLView id="detailEmployee" viewName="employees.view.Details" />
                            </f:midColumnPages>


                        </f:FlexibleColumnLayout>

                    </content>
                    <footer>
                        <Toolbar>
                            <Label text="{i18n>layout}" class="sapUiSmallMargin"/>
                            <Select items="{jsonLayout>/Layout}" selectedKey="{jsonLayout>/ActiveKey}">
                                <core:Item key="{jsonLayout>Key}" text="{jsonLayout>Text}"/>
                            </Select>
                        </Toolbar>
                    </footer>
                </Page>
            </pages>
        </App>
    </Shell>
</mvc:View>