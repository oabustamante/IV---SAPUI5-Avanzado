<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <Table items="{northwind>Orders}" width="700px">
        <columns>
            <Column>
                <header>
                    <Label text="{i18n>OrderID}" />
                </header>
            </Column>
            <Column>
                <header>
                    <Label text="{i18n>Freight}" />
                </header>
            </Column>
            <Column>
                <header>
                    <Label text="{i18n>ShipName}" />
                </header>
            </Column>
        </columns>
        <items>
            <ColumnListItem type="Navigation" press="toOrderDetails">
                <cells>
                    <Label text="{northwind>OrderID}" />
                    <Label text="{northwind>Freight}" />
                    <Label text="{northwind>ShipName}" />
                </cells>
            </ColumnListItem>
        </items>
    </Table>

</core:FragmentDefinition>